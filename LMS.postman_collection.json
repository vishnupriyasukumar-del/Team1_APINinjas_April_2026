      "name": "User Login Controller",
      "item": [
        {
          "name": "User Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const responseData = pm.response.json();",
                  "const lms_token = responseData.token;",
                  "pm.collectionVariables.set(\"lms_access_token\",lms_token);",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response to have the field token\",function(){",
                  "    pm.expect(responseData).to.have.property('token');",
                  "});",
                  "",
                  "pm.test(\"Response to have the field Type\",function(){",
                  "    pm.expect(responseData).to.have.property('type');",
                  "});",
                  "pm.test(\"Response to have the field userID\",function(){",
                  "    pm.expect(responseData).to.have.property('userId');",
                  "});",
                  "",
                  "pm.test(\"Response to have the field email\",function(){",
                  "    pm.expect(responseData).to.have.property('email');",
                  "});",
                  "",
                  "pm.test(\"Response to have the field roles\",function(){",
                  "    pm.expect(responseData).to.have.property('roles');",
                  "});",
                  "",
                  "pm.test(\"Response to have the field status\",function(){",
                  "    pm.expect(responseData).to.have.property('status');",
                  "});",
                  "",
                  "pm.test(\"Response to have the field password\",function(){",
                  "    pm.expect(responseData).to.have.property('passwordExpired')",
                  "});",
                  "",
                  "pm.test(\"validating response body data type for Token\", function () {",
                  "    pm.expect(responseData.token).to.be.a('string');",
                  "});",
                  "pm.test(\"validating response body data type for Type\", function () {",
                  "    pm.expect(responseData.type).to.be.a('string');",
                  "});",
                  "",
                  "pm.test(\"validating response body data type for userID\", function () {",
                  "      pm.expect(responseData.userId).to.be.a('string');",
                  "});",
                  "",
                  "pm.test(\"validating response body data type for email\", function () {",
                  "   pm.expect(responseData.email).to.be.a('string');",
                  "});",
                  "",
                  "pm.test(\"validating response body data type for roles\", function () {",
                  " pm.expect(responseData.roles).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"validating response body data type for status\", function () {",
                  "    pm.expect(responseData.status).to.be.a('string');",
                  "});",
                  "",
                  "pm.test(\"validating response body data type for passwordExpired\", function () {",
                  "    pm.expect(responseData.passwordExpired).to.be.a('boolean');",
                  "});",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
